# Supabase session pooler (runtime queries)
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@[REGION].pooler.supabase.com:5432/postgres"

# Supabase direct connection (required for Prisma schema operations)
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# JWT secret used for login/signup session cookies
JWT_SECRET="replace-with-a-long-random-secret"

# EmailJS configuration for share invite emails
EMAILJS_SERVICE_ID=""
EMAILJS_TEMPLATE_ID=""
EMAILJS_PUBLIC_KEY=""
EMAILJS_PRIVATE_KEY=""

# Public app URL used in invite links
NEXT_PUBLIC_APP_URL="http://localhost:3000"
